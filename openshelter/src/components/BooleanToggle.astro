---
// BooleanToggle.astro
interface Props {
  label: string;
  name: string;
  id?: string;
  checked?: boolean;
}

const { label, name, id = name, checked = false } = Astro.props;
---

<div class="toggle-container">
  <span class="label-text" id={`${id}-label`}>{label}</span>
  <label class="switch" for={id}>
    <input 
      type="checkbox" 
      id={id} 
      name={name} 
      checked={checked} 
      aria-labelledby={`${id}-label`}
    />
    <span class="slider"></span>
  </label>
</div>


<style>
  :root {
    --d-draeger-airblue: #0091f7;
    --d-draeger-darkblue: #002766;
  }

  .toggle-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: fit-content;
    font-family: sans-serif; /* Oder dein Projekt-Font */
  }

  .label-text {
    color: var(--d-draeger-darkblue);
    font-weight: 600;
  }

  .switch {
    position: relative;
    display: inline-block;
    width: 44px;
    height: 24px;
  }

  .switch input {
    opacity: 0;
    width: 0;
    height: 0;
  }

  .slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #ccc;
    transition: .4s;
    border-radius: 24px;
    border: 2px solid transparent;
  }

  .slider:before {
    position: absolute;
    content: "";
    height: 16px;
    width: 16px;
    left: 2px;
    bottom: 2px;
    background-color: white;
    transition: .4s;
    border-radius: 50%;
  }

  /* Aktiv-Zustand */
  input:checked + .slider {
    background-color: var(--d-draeger-airblue);
  }

  input:checked + .slider:before {
    transform: translateX(20px);
  }
</style>