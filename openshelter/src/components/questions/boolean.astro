---
interface Props {
	question: string;
}

const { question } = Astro.props;
---

<div class="question-container">
	<h2>{question}</h2>
	<div class="input-group">
		<label class="checkbox-label">
			<input type="checkbox" class="answer-checkbox" />
			<span class="checkmark"></span>
		</label>
	</div>
	<p class="response-message hidden"></p>
</div>

<script>
	document.querySelectorAll('.question-container').forEach((container) => {
		const checkbox = container.querySelector('.answer-checkbox') as HTMLInputElement;
		const message = container.querySelector('.response-message');

		checkbox?.addEventListener('change', () => {
			if (message) {
				message.textContent = checkbox.checked ? 'Antwort: Ja' : 'Antwort: Nein';
				message.classList.remove('hidden');
			}
		});
	});
</script>

<style>
	.question-container {
		max-width: 600px;
		margin: 2rem auto;
		padding: 2rem;
		background: rgba(255, 255, 255, 0.9);
		border-radius: 16px;
		box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
		backdrop-filter: blur(5px);
		border: 1px solid rgba(255, 255, 255, 0.3);
		font-family: Inter, Roboto, 'Helvetica Neue', Arial, sans-serif;
	}

	h2 {
		margin-top: 0;
		color: #111827;
		font-size: 1.5rem;
		margin-bottom: 1.5rem;
	}

	.input-group {
		display: flex;
		gap: 0.5rem;
	}

	.checkbox-label {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		cursor: pointer;
		font-size: 1rem;
		user-select: none;
	}

	.answer-checkbox {
		width: 1.25rem;
		height: 1.25rem;
		accent-color: var(--d-draeger-darkblue);
		cursor: pointer;
	}

	.response-message {
		margin-top: 1rem;
		color: #4b5563;
		font-size: 0.9rem;
	}

	.hidden {
		display: none;
	}
</style>
