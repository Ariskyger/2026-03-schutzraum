---
interface Props {
	question: string;
	name: string;
	checked?: boolean;
}

const { question, name, checked = false } = Astro.props;
---

<div class="question-container">
	<h2>{question}</h2>
	<div class="input-group">
		<label class="checkbox-label">
			<input type="checkbox" name={name} class="answer-checkbox" checked={checked} />
			<span class="checkmark"></span>
			<span class="cb-text">Ja</span>
		</label>
	</div>
</div>

<style>
	.question-container {
		max-width: 600px;
		margin: 1rem auto;
		padding: 2rem;
		background: rgba(255, 255, 255, 0.9);
		border-radius: 16px;
		box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
		backdrop-filter: blur(5px);
		border: 1px solid rgba(255, 255, 255, 0.3);
		font-family: Inter, Roboto, 'Helvetica Neue', Arial, sans-serif;
	}
	h2 {
		margin-top: 0;
		color: var(--d-draeger-darkblue, #111827);
		font-size: 1.25rem;
		margin-bottom: 1.5rem;
	}
	.input-group {
		display: flex;
		gap: 0.5rem;
	}
	.checkbox-label {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		cursor: pointer;
		font-size: 1rem;
		user-select: none;
	}
	.answer-checkbox {
		width: 1.25rem;
		height: 1.25rem;
		accent-color: var(--d-draeger-airblue, #0091f7);
		cursor: pointer;
	}
	.cb-text {
		color: #4b5563;
		font-size: 0.95rem;
	}
</style>
