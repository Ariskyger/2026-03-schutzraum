---
import astroLogo from "../assets/astro.svg";

const currentPath = Astro.url.pathname;
---

<nav class="navbar">
  <a href="/" class="navbar-logo">
    <img src={astroLogo.src} alt="Logo" width="32" height="32" />
  </a>
  <ul class="navbar-links">
    <li>
      <a href="/" class:list={["navbar-link", { active: currentPath === "/" }]}>
        Startseite
      </a>
    </li>
    <li>
      <a href="/wizard" class:list={["navbar-link", { active: currentPath === "/wizard" || currentPath === "/wizard/" }]}>
        Schutzraum
      </a>
    </li>
  </ul>
</nav>

<style>
  .navbar {
    display: flex;
    align-items: center;
    gap: 2rem;
    padding: 0.75rem 2rem;
    background-color: var(--d-draeger-darkblue);
  }

  .navbar-logo {
    display: flex;
    align-items: center;
  }

  .navbar-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.5rem;
  }

  .navbar-link {
    color: var(--d-draeger-white);
    text-decoration: none;
    font-family: Inter, Roboto, 'Helvetica Neue', Arial, sans-serif;
    font-size: 1rem;
    padding: 0.375rem 0.75rem;
    border-radius: 4px;
    transition: background-color 0.2s;
  }

  .navbar-link:hover,
  .navbar-link.active {
    background-color: var(--d-draeger-airblue);
  }
</style>
